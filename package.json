{
  "name": "@krislintigo/eslint-config-vue",
  "version": "1.2.0",
  "description": "Vue companion pieces for the shared ESLint flat config.",
  "type": "module",
  "license": "MIT",
  "author": "krislintigo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krislintigo/eslint-config-vue.git"
  },
  "homepage": "https://github.com/krislintigo/eslint-config-vue#readme",
  "bugs": {
    "url": "https://github.com/krislintigo/eslint-config-vue/issues"
  },
  "packageManager": "pnpm@10.33.2",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "types": "./src/index.d.ts",
  "scripts": {
    "prepare": "release-kit install-hooks",
    "commitlint": "release-kit commitlint",
    "check": "release-kit check",
    "release": "release-kit release",
    "release:dry-run": "release-kit release --dry-run"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "vue",
    "typescript"
  ],
  "peerDependencies": {
    "eslint": "^10.0.0",
    "typescript": ">=6.0.0 <7.0.0"
  },
  "devDependencies": {
    "@krislintigo/release-kit": "^1.3.0",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.64.0",
    "eslint-plugin-vue": "^10.9.2",
    "vue-eslint-parser": "^10.4.1"
  },
  "engines": {
    "node": ">=24.16.0"
  }
}
