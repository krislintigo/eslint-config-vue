{
  "name": "@krislintigo/eslint-config-vue",
  "version": "0.0.0",
  "description": "Vue companion pieces for the shared ESLint flat config.",
  "type": "module",
  "license": "MIT",
  "author": "krislintigo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krislintigo/eslint-config-vue.git"
  },
  "homepage": "https://github.com/krislintigo/eslint-config-vue#readme",
  "bugs": {
    "url": "https://github.com/krislintigo/eslint-config-vue/issues"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.9.0"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "types": "./src/index.d.ts",
  "scripts": {
    "check": "node --check src/index.js && tsc --noEmit --skipLibCheck --moduleResolution bundler --module esnext --target es2022 src/index.d.ts && pnpm pack --pack-destination /tmp",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "vue",
    "typescript"
  ],
  "peerDependencies": {
    "eslint": "^9.0.0",
    "typescript": ">=5.0.0 <7.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.39.4",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.59.4",
    "eslint-plugin-vue": "^10.9.1",
    "vue-eslint-parser": "^10.4.0"
  }
}
